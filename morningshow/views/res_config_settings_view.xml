<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mail</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='users_setting_container']" position="inside">
                <setting string="API URL" help="URL for the Morningshow API endpoint.">
                    <field name="morningshow_url" placeholder="https://api.example.com"/>
                </setting>

                <setting string="API Token" help="API token for authenticating with the Morningshow API.">
                    <field name="morningshow_api_token" password="True"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>